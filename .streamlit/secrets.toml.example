# =============================================================================
# CN88 Batch Directory — Secrets Template
# =============================================================================
# Copy this to .streamlit/secrets.toml and fill in your actual values.
# NEVER commit secrets.toml — it's in .gitignore for good reason.

# ---- GOOGLE OAUTH 2.0 (for st.login()) ----
[auth]
client_id = "YOUR_CLIENT_ID_FROM_GCP.apps.googleusercontent.com"
client_secret = "YOUR_CLIENT_SECRET_FROM_GCP"
redirect_uri = "http://localhost:8501/oauth2callback"  # Change to deployed URL in production
server_metadata_url = "https://accounts.google.com/.well-known/openid-configuration"
cookie_secret = "YOUR_STRONG_RANDOM_SECRET_HERE"       # Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"

# ---- GOOGLE SHEET (directory source) ----
[gsheet]
sheet_url = "https://docs.google.com/spreadsheets/d/1k-rMUMV_DYhuQxT5AhKUBr5tjaQICxhPN_4Lyt-TZQI/edit"
worksheet_name = "Form responses 1"

# ---- GOOGLE FORM (for "edit your entry" link) ----
[form]
url = "https://forms.gle/YOUR_FORM_ID_HERE"

# ---- SERVICE ACCOUNT (for reading the sheet) ----
# Paste the entire JSON key file contents here.
# This is the downloaded JSON from GCP → Service Accounts → Keys.
[gcp_service_account]
type = "service_account"
project_id = "cn88-directory"
private_key_id = "YOUR_PRIVATE_KEY_ID"
private_key = "-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE_WITH_NEWLINES\n-----END PRIVATE KEY-----\n"
client_email = "directory-reader@cn88-directory.iam.gserviceaccount.com"
client_id = "YOUR_SERVICE_ACCOUNT_CLIENT_ID"
auth_uri = "https://accounts.google.com/o/oauth2/auth"
token_uri = "https://oauth2.googleapis.com/token"
auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
client_x509_cert_url = "YOUR_CERT_URL"
