# Copy this to `.streamlit/secrets.toml` for local dev.
# For production, paste the same contents into Streamlit Cloud → App → Settings → Secrets.
# NEVER commit the real secrets.toml.

# ---------------------------------------------------------------------------
# 1. AUTH — Google Identity via Streamlit native OIDC (st.login)
# ---------------------------------------------------------------------------
[auth]
# LOCAL:       http://localhost:8501/oauth2callback
# PRODUCTION:  https://<your-app>.streamlit.app/oauth2callback
# Whatever you put here must ALSO be added as an Authorized redirect URI
# in your Google Cloud OAuth client.
redirect_uri = "http://localhost:8501/oauth2callback"

# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
cookie_secret = "REPLACE_WITH_RANDOM_48_CHAR_STRING"

# From Google Cloud → APIs & Services → Credentials → OAuth 2.0 Client ID
client_id = "xxxxxxxxxxxx.apps.googleusercontent.com"
client_secret = "GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxx"

# Shared across all Google OIDC clients — do not change.
server_metadata_url = "https://accounts.google.com/.well-known/openid-configuration"

# ---------------------------------------------------------------------------
# 2. GOOGLE SHEET — source of truth
# ---------------------------------------------------------------------------
[gsheet]
sheet_url = "https://docs.google.com/spreadsheets/d/1k-rMUMV_DYhuQxT5AhKUBr5tjaQICxhPN_4Lyt-TZQI/edit"
worksheet_name = "Form responses 1"

# ---------------------------------------------------------------------------
# 3. FORM URL — shown to users not yet in the directory
# ---------------------------------------------------------------------------
[form]
url = "https://forms.gle/YOUR_CN88_FORM_SHORTLINK"

# ---------------------------------------------------------------------------
# 4. SERVICE ACCOUNT — read-only access to the sheet (and thumbnails on Drive)
# Paste the downloaded JSON key contents here, key-by-key.
# ---------------------------------------------------------------------------
[gcp_service_account]
type = "service_account"
project_id = "cn88-directory"
private_key_id = "xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
private_key = "-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"
client_email = "directory-reader@cn88-directory.iam.gserviceaccount.com"
client_id = "123456789012345678901"
auth_uri = "https://accounts.google.com/o/oauth2/auth"
token_uri = "https://oauth2.googleapis.com/token"
auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
client_x509_cert_url = "https://www.googleapis.com/robot/v1/metadata/x509/directory-reader%40cn88-directory.iam.gserviceaccount.com"
universe_domain = "googleapis.com"
